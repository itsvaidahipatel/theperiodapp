# Supabase Configuration
SUPABASE_URL=your-supabase-url-here
SUPABASE_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# API Keys
GEMINI_API_KEY=your-gemini-api-key-here
RAPIDAPI_KEY=your-rapidapi-key-here

# JWT Configuration (optional - has defaults)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256

# CORS Configuration (optional - defaults to http://localhost:5173)
CORS_ORIGINS=http://localhost:5173

# Push Notification Configuration (Firebase placeholder)
# Install dependency when ready: pip install firebase-admin
FIREBASE_CREDENTIALS_PATH=/absolute/path/to/firebase-service-account.json
